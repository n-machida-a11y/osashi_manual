<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: sans-serif; margin: 20px; background-color: #f4f6f9; color: #333; }
    /* タイトルスタイル */
    h1 { font-size: 1.4em; color: #444; margin: 0 0 15px 0; display:flex; align-items:center; justify-content: flex-start; gap: 10px; }
    h1 span { border-bottom: 3px solid #007bff; padding-bottom: 5px; }
    
    /* タブデザイン */
    .tab-container { display: flex; margin-bottom: 15px; border-bottom: 2px solid #ddd; }
    .tab-item { 
      padding: 12px 25px; cursor: pointer; font-weight: bold; color: #666; 
      border-radius: 8px 8px 0 0; background: #e9ecef; margin-right: 5px; border: 1px solid #ddd; border-bottom: none;
      transition: all 0.2s;
    }
    .tab-item:hover { background: #dde2e6; }
    .tab-item.active { background: #fff; color: #007bff; border-bottom: 2px solid #fff; margin-bottom: -2px; }
    
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* サブタブ (JSON用) */
    .sub-tabs { display: flex; gap: 5px; margin-bottom: 15px; overflow-x: auto; padding-bottom: 5px; }
    .sub-tab-btn { padding: 6px 15px; border: 1px solid #007bff; background: #fff; color: #007bff; border-radius: 20px; cursor: pointer; font-size: 0.9em; white-space: nowrap; transition: 0.2s; }
    .sub-tab-btn.active { background: #007bff; color: #fff; }

    .card { background: #fff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 20px; padding: 20px; }
    
    .form-group { margin-bottom: 10px; }
    .form-group label { font-weight: bold; display: block; margin-bottom: 3px; font-size: 0.9em; color: #666; }
    .form-group input[type="text"], 
    .form-group input[type="date"], 
    .form-group select { 
      width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1em; height: 38px;
      font-family: inherit;
    }

    /* レイアウト */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .grid-tokuisaki-names { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .grid-1-8 { display: grid; grid-template-columns: 1fr 7fr; gap: 10px; }
    .grid-1-8-x2 { display: grid; grid-template-columns: 1fr 1fr 6fr; gap: 10px; }
    .grid-1-8-x3 { display: grid; grid-template-columns: 1fr 1fr 1fr 5fr; gap: 10px; }
    
    /* 商品リスト */
    .item-list { list-style: none; padding: 0; }
    .item { border-bottom: 1px solid #eee; padding: 15px 5px; }
    .item-header { display: flex; align-items: center; justify-content: space-between; font-weight: bold; }
    .item-left { display: flex; align-items: center; }
    .item-left > input.item-check { margin-right: 15px; transform: scale(1.5); }
    .item-details { font-size: 0.9em; color: #666; margin-top: 5px; padding-left: 35px; }
    .item-details span { margin-right: 15px; }
    .ship-input { margin-top: 10px; padding-left: 35px; }
    .ship-input input { width: 100px; padding: 5px; }
    .input-error { border: 2px solid red !important; background-color: #ffe6e6; }

    /* ボタン */
    .button { background-color: #007bff; color: white; padding: 12px; border: none; border-radius: 5px; cursor: pointer; width: 100%; font-size: 1.1em; margin-top: 10px; }
    .button:disabled { background-color: #aaa; }
    .button-warning { background-color: #ffc107; color: #333; }
    .button-danger { background-color: #dc3545; }
    .button-secondary { background-color: #6c757d; }
    .button-return { background-color: #6610f2; color: white; }
    .button-copy { background-color: #17a2b8; color: white; } 
    .button-success { background-color: #28a745; color: white; } 

    /* モードヘッダー */
    .edit-mode-header { background: #fff3cd; color: #856404; padding: 10px; border-radius: 5px; margin-bottom: 15px; border: 1px solid #ffeeba; display: none; text-align: center; font-weight: bold; }
    .copy-mode-header { background: #d1ecf1; color: #0c5460; padding: 10px; border-radius: 5px; margin-bottom: 15px; border: 1px solid #bee5eb; display: none; text-align: center; font-weight: bold; }

    /* 履歴画面スタイル */
    .history-container { display: grid; grid-template-columns: 300px 1fr; gap: 20px; height: 600px; }
    @media (max-width: 768px) {
      .history-container { grid-template-columns: 1fr; height: auto; }
      .preview-area { height: 500px; }
    }
    .history-list-scroll { height: 100%; overflow-y: auto; border: 1px solid #ddd; border-radius: 5px; background: #fff; }
    .history-card { border-bottom: 1px solid #eee; padding: 15px; cursor: pointer; transition: 0.2s; }
    .history-card:hover { background-color: #f0f8ff; }
    .history-card.selected { background-color: #e6f7ff; border-left: 4px solid #007bff; }
    .history-info { font-size: 0.9em; }
    
    .preview-area { display: flex; flex-direction: column; border: 1px solid #ddd; border-radius: 5px; background: #fff; overflow: hidden; }
    .preview-header { padding: 10px; background: #f8f9fa; border-bottom: 1px solid #ddd; display: flex; justify-content: space-between; align-items: center; flex-wrap:wrap; gap:5px; }
    .preview-frame { flex-grow: 1; border: none; width: 100%; height: 100%; background: #eee; }
    .preview-placeholder { display: flex; align-items: center; justify-content: center; height: 100%; color: #999; text-align: center; padding: 20px; }

    /* モーダル */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 200; }
    .modal-content { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #fff; padding: 20px; width: 90%; max-width: 700px; max-height: 90vh; overflow-y: auto; border-radius: 8px; }
    
    .return-header-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; }

    /* 自由入力エリア */
    .free-input-row { display: flex; gap: 5px; margin-bottom: 5px; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 5px; }
    .free-input-row input { font-size: 0.9em; padding: 5px; border: 1px solid #ccc; border-radius: 4px; }

    #loader { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.8); z-index: 999; text-align: center; padding-top: 40vh; font-size: 1.2em; }
    #message-area { display: none; padding: 15px; border-radius: 5px; margin-top: 20px; }
    .success { background-color: #d4edda; color: #155724; }
    .error { background-color: #f8d7da; color: #721c24; }
  </style>
</head>
<body>

  <!-- タブナビゲーション -->
  <div class="tab-container">
    <div class="tab-item active" onclick="switchTab('new')">📝 新規出荷作成</div>
    <div class="tab-item" onclick="switchTab('edit')">📂 作成済伝票の確認・修正</div>
  </div>

  <div id="main-content">
    <h1><span id="title-juchu-no">...</span> の出荷処理</h1>
    
    <!-- タブ1: 入力フォーム (新規・修正兼用) -->
    <div id="tab-new" class="tab-content active">
      
      <!-- 修正モード時の警告バー -->
      <div id="edit-mode-bar" class="edit-mode-header">
        ⚠️ 過去の伝票を修正中（元の伝票は削除され再作成されます）<br>
        <button class="button button-secondary" type="button" onclick="exitEditMode()" style="width:auto; padding:5px 10px; margin-left:10px; font-size:0.9em;">修正をやめて新規作成に戻る</button>
      </div>
      <!-- 複製モード時の警告バー -->
      <div id="copy-mode-bar" class="copy-mode-header">
        📋 過去の伝票を複製中（イレギュラー出荷・在庫変動なし）<br>
        受注Noを変更し、内容を修正してください。<br>
        <button class="button button-secondary" type="button" onclick="exitCopyMode()" style="width:auto; padding:5px 10px; margin-left:10px; font-size:0.9em;">キャンセル</button>
      </div>

      <!-- JSON連携サブタブ -->
      <div id="delivery-tabs" class="sub-tabs"></div>

      <div class="card">
        <!-- 作成者 -->
        <div class="grid-2" style="margin-bottom: 15px; border-bottom: 1px dashed #ccc; padding-bottom: 15px;">
           <div class="form-group">
             <label style="color:#007bff;">👤 作成者 (必須)</label>
             <select id="creator-name" style="border-color:#007bff; background:#f0f8ff;">
                <option value="">-- 選択してください --</option>
             </select>
           </div>
           <div></div>
        </div>

        <!-- 得意先コード (1/8幅) -->
        <div class="grid-1-8">
          <div class="form-group"><label>得意先コード</label><input type="text" id="tokuisaki-code"></div>
          <div class="grid-tokuisaki-names">
             <div class="form-group"><label>得意先名</label><input type="text" id="tokuisaki-name"></div>
             <div class="form-group"><label>得意先名２</label><input type="text" id="tokuisaki-name2"></div> 
          </div>
        </div>

        <div class="grid-2">
          <div class="form-group"><label>先方担当者名</label><input type="text" id="senpo-tantosha"></div>
          <div><!-- 余白 --></div>
        </div>
        
        <div class="grid-2">
          <div class="form-group"><label>直送先名</label><input type="text" id="chokusosaki-name"></div>
          <div class="form-group"><label>直送先名２</label><input type="text" id="chokusosaki-name2"></div>
        </div>
        
        <div class="grid-2">
          <div class="form-group"><label>直送先担当者名</label><input type="text" id="chokusosaki-tantosha"></div>
          <div><!-- 余白 --></div>
        </div>
        
        <div class="grid-1-8-x2">
          <div class="form-group"><label>郵便番号</label><input type="text" id="postal-code"></div>
          <div class="form-group"><label>会社TEL</label><input type="text" id="kaisha-tel"></div>
          <div><!-- 余白 --></div>
        </div>

        <div class="form-group"><label>住所１</label><input type="text" id="address1"></div>
        <div class="form-group"><label>住所２</label><input type="text" id="address2"></div>

        <div class="grid-1-8-x2">
          <div class="form-group"><label>FM情報No</label><input type="text" id="fm-info-no"></div>
          <div class="form-group"><label>FM出荷No</label><input type="text" id="fm-shukka-no"></div>
          <div><!-- 余白 --></div>
        </div>

        <div class="grid-1-8-x3" style="margin-top: 15px;">
          <div class="form-group">
             <label>出荷日</label>
             <input type="date" id="shipping-date">
          </div>
          <div class="form-group">
             <label>到着日</label>
             <input type="date" id="arrival-date">
          </div>
          <div class="form-group">
             <label>到着時刻</label>
             <select id="arrival-time">
               <option value="午前中">午前中</option>
               <option value="14時～16時">14時～16時</option>
               <option value="16時～18時">16時～18時</option>
               <option value="18時以降">18時以降</option>
               <option value="指定なし">指定なし</option>
             </select>
          </div>
          <div><!-- 余白 --></div>
        </div>
      </div>

      <div class="card">
        <div class="select-all" style="padding:10px; background:#f0f0f0; margin-bottom:10px;">
          <input type="checkbox" id="check-all" onchange="toggleAll(this)">
          <label for="check-all">全選択</label>
        </div>
        <ul id="item-list-container" class="item-list"></ul>
        
        <!-- 自由入力エリア (複製モードのみ表示) -->
        <div id="free-input-area" style="display:none; margin-top:20px; border-top:2px dashed #ddd; padding-top:15px;">
          <div style="font-weight:bold; color:#17a2b8; margin-bottom:10px;">📋 自由入力欄（登録外の商品はこちら）</div>
          <div style="font-size:0.8em; color:#666; margin-bottom:5px;">品名 / 数量 / シリアルNo を入力してください。</div>
          <div id="free-item-container"></div>
          <button class="button button-secondary" type="button" onclick="addFreeInputRow()" style="width:auto; font-size:0.9em; margin-top:10px;">＋ 自由入力行を追加</button>
        </div>
      </div>
      
      <!-- 保存ボタン -->
      <button id="submit-button" class="button" type="button" onclick="handleSubmit()">出荷伝票を作成する</button>
    </div>

    <!-- タブ2: 履歴一覧 & プレビュー -->
    <div id="tab-edit" class="tab-content">
      <div class="card" style="padding:15px; margin-bottom:10px;">
        <button class="button button-secondary" type="button" onclick="loadHistoryList()" style="width:auto; margin-top:0;">🔄 リストを更新</button>
        <span style="margin-left:10px; font-size:0.9em; color:#666;">※プレビューが表示されない場合は「ファイルを開く」をご利用ください。</span>
      </div>

      <div class="history-container">
        <!-- 左：リスト -->
        <div class="history-list-scroll" id="history-list-area">
          <div style="padding:20px; text-align:center;">読み込み中...</div>
        </div>

        <!-- 右：プレビュー -->
        <div class="preview-area">
          <div class="preview-header">
            <strong id="preview-title">伝票プレビュー</strong>
            <div style="display:flex; gap:5px;">
              <a id="preview-link" href="#" target="_blank" style="margin-right:10px; display:none; align-self:center;">別タブで開く</a>
              <!-- 各種ボタン -->
              <button id="preview-confirm-btn" class="button button-success" type="button" style="width:auto; padding:5px 15px; margin:0; font-size:0.9em; display:none;">✅ 確認済にする</button>
              <button id="preview-return-btn" class="button button-return" type="button" style="width:auto; padding:5px 15px; margin:0; font-size:0.9em; display:none;">↩️ 返品処理</button>
              <button id="preview-copy-btn" class="button button-copy" type="button" style="width:auto; padding:5px 15px; margin:0; font-size:0.9em; display:none;">📋 複製</button>
              <button id="preview-edit-btn" class="button button-warning" type="button" style="width:auto; padding:5px 15px; margin:0; font-size:0.9em; display:none;">🛠️ 修正</button>
            </div>
          </div>
          <div id="preview-placeholder" class="preview-placeholder">
            <div>左のリストから伝票を選択すると<br>ここにスプレッドシートが表示されます</div>
          </div>
          <iframe id="preview-frame" class="preview-frame" style="display:none;"></iframe>
        </div>
      </div>
    </div>

  </div>
  
  <!-- 確認者登録用モーダル -->
  <div id="confirm-modal" class="modal-overlay">
    <div class="modal-content" style="max-width: 400px;">
      <h3 style="color:#28a745; margin-top:0;">✅ 確認者の登録（プルダウン選択）</h3>
      <p style="font-size:0.9em; color:#666;">明細書の「確認」欄に名前を追記します。</p>
      <div class="form-group">
        <label>確認者</label>
        <select id="confirm-name-select"></select>
      </div>
      <div style="display:flex; justify-content:space-between; margin-top:20px;">
        <button class="button button-secondary" type="button" style="width:48%;" onclick="closeConfirmModal()">キャンセル</button>
        <button class="button button-success" type="button" style="width:48%;" onclick="submitConfirm()">実行する</button>
      </div>
    </div>
  </div>

  <!-- 返品用モーダル -->
  <div id="return-modal" class="modal-overlay">
    <div class="modal-content">
      <h2 style="border-bottom:2px solid #6610f2; padding-bottom:10px; margin-top:0; color:#6610f2;">↩️ 返品処理</h2>
      
      <div class="return-header-grid">
        <div class="form-group"><label>入荷日</label><input type="date" id="return-date"></div>
        <div class="form-group"><label>完了日</label><input type="date" id="return-complete-date"></div>
        <div class="form-group"><label>返品依頼No</label><input type="text" id="return-req-no" placeholder="手入力"></div>
        <div class="form-group">
          <label>送料負担</label>
          <select id="return-ship-type"><option value="元払い">元払い</option><option value="着払い">着払い</option></select>
        </div>
        <div class="form-group" style="grid-column: span 2;"><label>送料金額 (着払い時)</label><input type="text" id="return-ship-cost" placeholder="円"></div>
      </div>

      <div style="background:#f8f9fa; padding:10px; border-radius:5px; margin-bottom:15px;">
        <label style="font-weight:bold;">返品する商品と数量</label>
        <ul id="return-item-list" class="item-list"></ul>
      </div>

      <div style="display:flex; justify-content:space-between;">
        <button class="button button-secondary" type="button" style="width:48%;" onclick="closeReturnModal()">キャンセル</button>
        <button class="button button-return" type="button" style="width:48%;" onclick="submitReturn()">返品を実行</button>
      </div>
    </div>
  </div>

  <div id="message-area"></div>
  <div id="loader"><p>データを読み込み中です...</p></div>

  <script>
    const initialJuchuNo = "<?= juchuNo ?>";
    const initialSlipId = "<?= initialSlipId ?>"; 
    const initialTab = "<?= initialTab ?>";
    const APP_URL = "<?= ScriptApp.getService().getUrl() ?>";

    let gData = {}; 
    let editingSlipId = null; 
    let isEditMode = false; 
    let isCopyMode = false;
    let currentReturnSlipId = null; 
    let currentConfirmSlipId = null; 
    
    // JSON連携用
    let currentDeliveryIndex = 0; 

    window.onload = function() {
      if (initialSlipId) {
        startEditDirectly(initialSlipId);
      } else {
        loadMasterData(initialJuchuNo);
        if (initialTab === 'edit') {
            switchTab('edit');
        }
      }
      setTodayToDateInput('shipping-date');
      setTodayToDateInput('arrival-date');
      setTodayToDateInput('return-date');
      setTodayToDateInput('return-complete-date');
    };

    function setTodayToDateInput(id) {
      const d = new Date();
      d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
      document.getElementById(id).value = d.toISOString().split('T')[0];
    }

    function formatDateForInput(dateStr) {
      if (!dateStr) return '';
      return dateStr.replace(/\//g, '-');
    }

    function loadMasterData(juchuNo) {
      showLoader(true, '受注データを読み込んでいます...');
      google.script.run
        .withSuccessHandler(initMasterData)
        .withFailureHandler(showError)
        .getSalesOrderData(juchuNo);
    }

    function startEditDirectly(slipId) {
      showLoader(true, '指定された伝票を読み込んでいます...');
      google.script.run
        .withSuccessHandler((data) => {
           if(data.status==='error'){ showError(data.message); return; }
           initMasterData(data);
           switchTab('edit');
        })
        .withFailureHandler(showError)
        .getSalesOrderData(null, slipId);
    }

    function initMasterData(data) {
      showLoader(false);
      if(data.status === 'error') { showError(data.message); return; }
      gData = data;
      document.getElementById('title-juchu-no').innerText = data.juchuNo;
      
      // 作成者・確認者プルダウンの生成
      const creatorSelect = document.getElementById('creator-name');
      const confirmSelect = document.getElementById('confirm-name-select');
      creatorSelect.innerHTML = '<option value="">-- 選択してください --</option>';
      confirmSelect.innerHTML = '<option value="">-- 選択してください --</option>';
      
      if (data.creatorList) {
        data.creatorList.forEach(name => {
          creatorSelect.innerHTML += `<option value="${name}">${name}</option>`;
          confirmSelect.innerHTML += `<option value="${name}">${name}</option>`;
        });
      }

      setFormValues(data);
      renderItemList(data.meisaiList);
      renderDeliveryTabs();
      loadHistoryList();
    }

    // --- JSON連携のサブタブ処理 ---
    function renderDeliveryTabs() {
      const tabContainer = document.getElementById('delivery-tabs');
      tabContainer.innerHTML = '';
      currentDeliveryIndex = 0; 

      if (!gData.deliveryList || gData.deliveryList.length === 0) {
         gData.deliveryList = [{}];
      }

      gData.deliveryList.forEach((deliv, index) => {
        const btn = document.createElement('button');
        btn.type = 'button'; 
        btn.className = `sub-tab-btn ${index === 0 ? 'active' : ''}`;
        btn.innerText = `${index + 1}回目`;
        btn.onclick = () => selectDeliveryTab(index);
        tabContainer.appendChild(btn);
      });

      applyDeliveryDataToForm(0);
    }

    // ★追加: 修正モード中は対象以外のタブをロックする関数
    function lockDeliveryTabs() {
      document.querySelectorAll('.sub-tab-btn').forEach((btn, i) => {
        if (i !== currentDeliveryIndex) {
          btn.disabled = true;
          btn.style.opacity = '0.5';
          btn.style.cursor = 'not-allowed';
        }
      });
    }

    // ★追加: タブのロックを解除する関数
    function unlockDeliveryTabs() {
      document.querySelectorAll('.sub-tab-btn').forEach((btn) => {
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
      });
    }

    function selectDeliveryTab(index) {
      saveFormToDeliveryData(currentDeliveryIndex);
      currentDeliveryIndex = index;
      document.querySelectorAll('.sub-tab-btn').forEach((btn, i) => {
        btn.className = `sub-tab-btn ${i === index ? 'active' : ''}`;
      });
      applyDeliveryDataToForm(index);
    }

    function applyDeliveryDataToForm(index) {
      if (!gData.deliveryList || !gData.deliveryList[index]) return;
      const d = gData.deliveryList[index];
      
      document.getElementById('fm-info-no').value = d.informationNo || '';
      document.getElementById('fm-shukka-no').value = d.shippingNo || '';
      if (d.shipDate) document.getElementById('shipping-date').value = formatDateForInput(d.shipDate);
      if (d.deliveryDate) document.getElementById('arrival-date').value = formatDateForInput(d.deliveryDate);
      
      const timeSelect = document.getElementById('arrival-time');
      if (d.deliveryTime) {
         let found = false;
         for (let i=0; i<timeSelect.options.length; i++) {
            if (timeSelect.options[i].value === d.deliveryTime) {
                timeSelect.selectedIndex = i;
                found = true; break;
