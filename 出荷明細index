        if (qty > 0) {
          items.push({
            meisaiNo: li.dataset.meisaiNo,
            rowNum: gData.meisaiList.find(m => String(m.meisaiNo) === li.dataset.meisaiNo).rowNum,
            shohinCode: li.dataset.shohinCode,
            shohinName: li.dataset.shohinName,
            returnQty: qty,
            serialNo: serial
          });
          totalReturn += qty;
        }
      });
      if (totalReturn === 0) { alert('返品する数量を入力してください。'); return; }
      const returnData = {
        juchuNo: gData.juchuNo,
        slipId: currentReturnSlipId,
        returnDate: document.getElementById('return-date').value,
        completeDate: document.getElementById('return-complete-date').value,
        returnReqNo: document.getElementById('return-req-no').value,
        shippingCostType: document.getElementById('return-ship-type').value,
        shippingCost: document.getElementById('return-ship-cost').value,
        tantoshaName: gData.tantoshaName, // 受注担当者
        items: items
      };
      showLoader(true, '返品処理を実行中...');
      google.script.run.withSuccessHandler((res) => {
          showLoader(false);
          if (res.status === 'error') { showError(res.message); } 
          else { alert('返品処理が完了しました。'); closeReturnModal(); loadMasterData(gData.juchuNo); }
        }).withFailureHandler(showError).processReturn(returnData);
    }
  </script>
</body>
</html>
