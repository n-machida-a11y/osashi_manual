    function loadHistoryDetail(slipId, mode, targetTabIndex) {
      showLoader(true, '伝票データを復元中...');
      google.script.run.withSuccessHandler(detailsRes => {
         if(detailsRes.status === 'error') { showError('明細データの取得に失敗しました: ' + detailsRes.message); return; }
         google.script.run.withSuccessHandler(listRes => {
            showLoader(false);
            if(listRes.status === 'error') { showError('リストデータの取得に失敗しました: ' + listRes.message); return; }
            const hist = listRes.historyList.find(h => String(h.slipId) === String(slipId));
            if(!hist) { alert('履歴データが見つかりません'); return; }

            if (mode === 'edit') enterEditMode(slipId);
            else if (mode === 'copy') enterCopyMode(slipId);

            setFormValues(hist);
            
            // ★修正: 履歴から復元する際は、JSONデータを上書きしないように見た目とインデックスのみ変更
            if ((mode === 'edit' || mode === 'copy') && targetTabIndex !== '' && targetTabIndex !== null) {
               currentDeliveryIndex = parseInt(targetTabIndex, 10);
               document.querySelectorAll('.sub-tab-btn').forEach((btn, i) => {
                 btn.className = `sub-tab-btn ${i === currentDeliveryIndex ? 'active' : ''}`;
               });
            }

            // ★追加: 修正・複製モード中は対象以外のタブを触れないようにロック
            if (mode === 'edit' || mode === 'copy') {
               lockDeliveryTabs();
            }

            if (mode === 'copy') {
               setTodayToDateInput('shipping-date');
               setTodayToDateInput('arrival-date');
            } else {
               document.getElementById('shipping-date').value = hist.shippingDate;
               document.getElementById('arrival-date').value = hist.arrivalDate;
            }
            document.getElementById('arrival-time').value = hist.arrivalTime;
            document.getElementById('creator-name').value = hist.creatorName || '';

            renderItemList(gData.meisaiList, detailsRes.details);
         }).getShipmentHistoryList(gData.juchuNo);
      }).getHistoryDetails(slipId);
    }

