    function renderItemList(list, quantityMap = {}) {
      const container = document.getElementById('item-list-container');
      container.innerHTML = '';
      document.getElementById('check-all').checked = false;

      list.forEach(item => {
        const li = document.createElement('li');
        li.className = 'item';
        
        let savedQty = 0;
        const targetKey = String(item.meisaiNo).trim();
        if (quantityMap.hasOwnProperty(targetKey)) {
            savedQty = quantityMap[targetKey];
        } else {
            for (const k in quantityMap) {
                if (String(k).trim() === targetKey) { savedQty = quantityMap[k]; break; }
            }
        }
        
        const dbZumi = Number(item.shukkaZumiSuryo);
        const juchu = Number(item.juchuSuryo);
        const currentKano = juchu - dbZumi;
        
        let limit;
        if (isEditMode) limit = currentKano + savedQty;
        else if (isCopyMode) limit = 9999; 
        else limit = currentKano;

        li.dataset.meisaiNo = item.meisaiNo;
        li.dataset.rowNum = item.rowNum;
        li.dataset.shohinCode = item.shohinCode;
        li.dataset.shohinName = item.shohinName;
        li.dataset.limit = limit;

        const isChecked = savedQty > 0;
        const isDisabled = limit <= 0;

        li.innerHTML = `
          <div class="item-header">
            <div class="item-left">
              <div class="exclude-wrapper" style="position: relative; margin-right: 15px; display: flex; align-items: center;">
                  <input type="checkbox" class="item-exclude-check" onchange="toggleInput(this, 'exclude')" style="transform: scale(1.5);" ${isDisabled ? 'disabled' : ''}>
                  <label style="position: absolute; top: 18px; left: 50%; transform: translateX(-50%); font-size: 0.7em; color: #d9534f; margin:0; width: max-content;">除外</label>
              </div>
              <input type="checkbox" class="item-check" onchange="toggleInput(this, 'main')" ${isChecked ? 'checked' : ''} ${isDisabled ? 'disabled' : ''}>
              <strong>${item.shohinName}</strong>
            </div>
          </div>
          <div class="item-details">
            <span>受注: ${juchu}</span>
            <span>済: ${dbZumi}</span>
            <span><strong>残: ${currentKano}</strong></span>
            ${isEditMode && savedQty > 0 ? `<span style="color:#007bff; font-weight:bold;">(保存済: ${savedQty})</span>` : ''}
          </div>
          <div class="ship-input">
            <label>今回数 (Max:${limit}):</label>
            <input type="number" class="item-quantity" value="${isChecked ? savedQty : ''}" max="${limit}" min="0" ${isChecked ? '' : 'disabled'}>
          </div>
        `;
        container.appendChild(li);
      });
    }

    function toggleInput(checkbox, type) {
      const li = checkbox.closest('.item');
      const mainCheck = li.querySelector('.item-check');
      const excludeCheck = li.querySelector('.item-exclude-check');
      const input = li.querySelector('.item-quantity');
      const limit = li.dataset.limit;
      if (type === 'main' && checkbox.checked) excludeCheck.checked = false;
      else if (type === 'exclude' && checkbox.checked) mainCheck.checked = false;
      
      if (mainCheck.checked || excludeCheck.checked) {
        input.disabled = false;
        if (input.value === '' || input.value === '0') input.value = limit > 999 ? '' : limit;
      } else {
        input.disabled = true;
        input.value = '';
        input.classList.remove('input-error');
      }
    }
    
    function toggleAll(main) {
      document.querySelectorAll('.item-check').forEach(c => { 
        if(!c.disabled) { 
          c.checked = main.checked; 
          if(main.checked) c.closest('.item').querySelector('.item-exclude-check').checked = false;
          toggleInput(c, 'main'); 
        }
      });
    }

    function handleSubmit() {
      try {
        const creatorName = document.getElementById('creator-name').value;
        if (!creatorName) { alert('作成者を選択してください。'); return; }

        const items = [];
        let hasError = false;
        let checkedCount = 0;

        document.querySelectorAll('#item-list-container .item').forEach(li => {
          const mainCheck = li.querySelector('.item-check');
          const excludeCheck = li.querySelector('.item-exclude-check');
          if (mainCheck.checked || excludeCheck.checked) {
            checkedCount++;
            const input = li.querySelector('.item-quantity');
            const val = parseInt(input.value);
            const limit = parseInt(li.dataset.limit);
            input.classList.remove('input-error');
            if(isNaN(val) || val < 0) { alert('数量不正'); input.classList.add('input-error'); hasError=true; return; }
            if(val > limit) { alert('数量オーバー'); input.classList.add('input-error'); hasError=true; return; }
            items.push({
              meisaiNo: li.dataset.meisaiNo,
              rowNum: li.dataset.rowNum,
              shohinCode: li.dataset.shohinCode,
              shohinName: li.dataset.shohinName,
              shukkaSu: val,
              excludeFromSlip: excludeCheck.checked 
            });
          }
        });

        if (isCopyMode) {
          document.querySelectorAll('#free-item-container .free-input-row').forEach(row => {
            const name = row.querySelector('.free-name').value;
            const qty = parseInt(row.querySelector('.free-qty').value);
            const serial = row.querySelector('.free-serial').value;
            if (name && qty > 0) {
              checkedCount++;
              items.push({
                meisaiNo: null, 
                shohinCode: '',
                shohinName: name,
                shukkaSu: qty,
                serialNo: serial,
                isFreeInput: true,
                excludeFromSlip: false
              });
            }
          });
        }

        if (checkedCount === 0) { alert('商品を選択してください'); return; }
        if (hasError) return;
        
        let confirmMsg = '出荷伝票を作成しますか？';
        if (isEditMode) confirmMsg = '⚠️ 元の伝票を削除し、内容を上書き再作成します。\nよろしいですか？';
        if (isCopyMode) confirmMsg = '📋 在庫を変動させずに伝票を作成します。\nよろしいですか？';

        if(!confirm(confirmMsg)) return;
        
        let finalJuchuNo = gData.juchuNo;
        if (isCopyMode) {
          const inputJ = document.getElementById('input-juchu-no');
          if (inputJ) finalJuchuNo = inputJ.value;
        }

        saveFormToDeliveryData(currentDeliveryIndex);

        const sendData = {
          juchuNo: gData.juchuNo, 
          newJuchuNo: finalJuchuNo, 
          originalSlipId: editingSlipId, 
          isIrregular: isCopyMode, 
          creatorName: creatorName, 
          targetTabIndex: isCopyMode ? null : currentDeliveryIndex, 
          deliveryList: gData.deliveryList, 

          tokuisakiCode: document.getElementById('tokuisaki-code').value,
          tokuisakiName: document.getElementById('tokuisaki-name').value,
          tokuisakiName2: document.getElementById('tokuisaki-name2').value,
          senpoTantoshaName: document.getElementById('senpo-tantosha').value,
          chokusosakiName: document.getElementById('chokusosaki-name').value,
          chokusosakiName2: document.getElementById('chokusosaki-name2').value,
          chokusosakiTantoshaName: document.getElementById('chokusosaki-tantosha').value,
          postalCode: document.getElementById('postal-code').value,
          address1: document.getElementById('address1').value,
          address2: document.getElementById('address2').value,
          kaishaTel: document.getElementById('kaisha-tel').value,
          fmInfoNo: document.getElementById('fm-info-no').value, 
          fmShukkaNo: document.getElementById('fm-shukka-no').value, 
          shippingDate: document.getElementById('shipping-date').value,
          arrivalDate: document.getElementById('arrival-date').value,
          arrivalTime: document.getElementById('arrival-time').value,
          tantoshaName: gData.tantoshaName, 
          items: items
        };
        
        showLoader(true, isEditMode ? '上書き再作成中...' : '伝票作成中...');
        const handler = isEditMode ? 'updateShipment' : 'processShipment';
        google.script.run
          .withSuccessHandler(showSuccess)
          .withFailureHandler(showError)
          [handler](sendData);
      } catch(e) {
        showError('予期せぬエラーが発生しました: ' + e.message);
      }
    }

