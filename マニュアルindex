<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>受注・出荷管理システム マニュアル</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { corePlugins: { preflight: false } }</script>

  <style>
    /* ===== ベース ===== */
    html { scroll-behavior: smooth; font-size: 17px; }
    body {
      font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;
      background: #f0f4f8;
      display: flex;
      color: #222;
    }

    /* ===== 左サイドバー ===== */
    .sidebar {
      width: 248px; min-width: 248px; min-height: 100vh;
      background: #1e3a5f; color: #fff;
      position: fixed; top: 0; left: 0;
      overflow-y: auto; z-index: 100;
      display: flex; flex-direction: column;
    }
    .sidebar-logo {
      padding: 22px 18px 16px;
      background: #0f1f36;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-logo .app-name { font-size: 1rem; font-weight: 800; color: #fff; line-height: 1.4; }
    .sidebar-logo .sub { font-size: 0.73rem; color: #7da8d0; margin-top: 3px; }
    .nav-group-label {
      padding: 14px 18px 5px;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: #4a7099;
    }
    .sidebar a {
      display: block; padding: 9px 18px;
      color: #93b8d8; text-decoration: none;
      font-size: 0.85rem; border-left: 3px solid transparent;
      transition: all 0.15s;
    }
    .sidebar a:hover { background: #254a6e; color: #fff; border-left-color: #3b82f6; }
    .sidebar a.active { background: #1d3f5e; color: #fff; border-left-color: #60a5fa; font-weight: 700; }

    /* ===== メイン ===== */
    .main { margin-left: 248px; flex: 1; }

    /* ===== カバー ===== */
    .cover {
      background: linear-gradient(135deg, #0f1f36 0%, #1e3a5f 60%, #1a4a7a 100%);
      color: #fff; padding: 56px 52px;
      position: relative; overflow: hidden;
    }
    .cover::before {
      content: ''; position: absolute; top: -60px; right: -60px;
      width: 340px; height: 340px; border-radius: 50%;
      background: rgba(59,130,246,0.12); pointer-events: none;
    }
    .cover .tag {
      display: inline-block; background: #3b82f6; color: #fff;
      font-size: 0.75rem; font-weight: 700; padding: 3px 14px;
      border-radius: 20px; margin-bottom: 14px; letter-spacing: 0.06em;
    }
    .cover h1 { font-size: 1.9rem; font-weight: 900; margin-bottom: 6px; line-height: 1.3; }
    .cover .sub { font-size: 1rem; color: #93b8d8; }

    /* ===== セクション ===== */
    .section { padding: 48px 52px; background: #fff; border-bottom: 1px solid #e2e8f0; }
    .section.alt { background: #fafbfd; }
    .section-label {
      display: inline-block; background: #1e3a5f; color: #fff;
      font-size: 0.68rem; font-weight: 700; padding: 3px 11px;
      border-radius: 4px; margin-bottom: 10px;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .section h2 {
      font-size: 1.65rem; font-weight: 800; color: #1e3a5f;
      border-bottom: 3px solid #3b82f6; display: inline-block;
      padding-bottom: 9px; margin-bottom: 8px;
    }
    .section-intro {
      font-size: 1rem; color: #444; line-height: 1.9;
      margin: 14px 0 26px;
    }
    .section h3 {
      font-size: 1.1rem; font-weight: 700; color: #1e3a5f;
      margin: 32px 0 14px; padding-left: 12px;
      border-left: 4px solid #3b82f6;
    }

    /* ===== フロー図 ===== */
    .flow-wrap {
      background: #f0f4f8; border-radius: 10px; padding: 22px 26px;
      margin: 18px 0; display: flex; align-items: center; flex-wrap: wrap; gap: 0;
    }
    .flow-step {
      text-align: center; padding: 11px 15px; border-radius: 8px;
      font-size: 0.85rem; font-weight: 700; min-width: 106px;
      color: #fff; line-height: 1.45;
    }
    .flow-step small { font-size: 0.72rem; font-weight: 400; opacity: 0.85; display: block; margin-top: 3px; }
    .flow-arrow { padding: 0 6px; color: #3b82f6; font-size: 1.3rem; font-weight: 700; }

    /* ===== 役割バッジ ===== */
    .role-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
    .role-lbl { font-size: 0.82rem; color: #888; }
    .badge-sales  { background: #dbeafe; color: #1d4ed8; }
    .badge-office { background: #dcfce7; color: #15803d; }
    .badge-mgr    { background: #f3e8ff; color: #7c3aed; }

    /* ===== ステップbox ===== */
    .step-box {
      background: #fff; border-radius: 9px; padding: 20px 22px;
      margin-bottom: 18px; box-shadow: 0 2px 7px rgba(0,0,0,0.07);
      border-left: 5px solid #3b82f6;
    }
    .step-box h5 {
      font-size: 1.02rem; font-weight: 700; color: #1e3a5f;
      margin-bottom: 10px; display: flex; align-items: center; gap: 8px;
    }
    .step-box p { font-size: 0.95rem; color: #333; line-height: 1.85; margin-bottom: 6px; }
    .step-box ul, .step-box ol {
      font-size: 0.95rem; color: #333; line-height: 1.85;
      margin-bottom: 0; padding-left: 22px;
    }
    .step-box li { margin-bottom: 4px; }
    .step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; background: #3b82f6; color: #fff;
      border-radius: 50%; font-size: 0.85rem; font-weight: 700;
      flex-shrink: 0;
    }

    /* ===== モックアップ ===== */
    .mockup-wrap {
      border: 1px solid #d0d7e0; border-radius: 10px; overflow: hidden;
      box-shadow: 0 4px 16px rgba(0,0,0,0.08); margin: 22px 0;
    }
    .browser-bar {
      background: #f1f3f5; padding: 8px 13px;
      display: flex; align-items: center; gap: 7px;
      border-bottom: 1px solid #e2e8f0;
    }
    .bdot { width: 10px; height: 10px; border-radius: 50%; }
    .bdot:nth-child(1) { background: #ff5f57; }
    .bdot:nth-child(2) { background: #febc2e; }
    .bdot:nth-child(3) { background: #28c840; }
    .burl {
      flex: 1; background: #fff; border: 1px solid #dde; border-radius: 4px;
      padding: 3px 10px; font-size: 0.74rem; color: #888;
    }

    /* ===== 画像プレースホルダー ===== */
    .image-placeholder {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: #e8edf3; border: 2px dashed #94a3b8; border-radius: 8px;
      min-height: 120px; margin: 16px 0; color: #64748b;
      font-size: 0.92rem; padding: 24px; text-align: center;
    }
    .image-placeholder img { max-width: 100%; height: auto; border-radius: 6px; display: none; }
    .image-placeholder img[src]:not([src=""]) { display: block; }
    .image-placeholder img[src]:not([src=""]) + div { display: none; }

    /* ===== ノート ===== */
    .note {
      background: #eff6ff; border-left: 4px solid #3b82f6;
      padding: 13px 17px; border-radius: 0 7px 7px 0;
      margin: 16px 0; font-size: 0.93rem; line-height: 1.8;
    }
    .note.warn   { background: #fffbeb; border-color: #f59e0b; }
    .note.danger { background: #fef2f2; border-color: #ef4444; }
    .note-title  { font-weight: 700; margin-bottom: 4px; color: #1d4ed8; font-size: 0.95rem; }
    .note.warn  .note-title { color: #b45309; }
    .note.danger .note-title { color: #b91c1c; }

    /* ===== フッター ===== */
    .footer {
      padding: 30px 52px; background: #1e3a5f;
      color: #4a7099; font-size: 0.85rem; text-align: center;
    }

    /* ===== 管理者 画像アップロード ===== */
    .upload-label {
      cursor: pointer; white-space: nowrap;
      font-size: 0.82rem;
    }
    .upload-label input[type="file"] { display: none; }

    /* ===== PDFダウンロードボタン ===== */
    .pdf-btn {
      display: flex; align-items: center; justify-content: center; gap: 7px;
      width: calc(100% - 36px); margin: 12px 18px;
      padding: 10px 0; border-radius: 7px;
      background: #3b82f6; color: #fff; border: none;
      font-size: 0.85rem; font-weight: 700; cursor: pointer;
      transition: background 0.15s;
    }
    .pdf-btn:hover { background: #2563eb; }

    /* ===== 印刷・PDF出力 ===== */
    @media print {
      .sidebar { display: none !important; }
      .main { margin-left: 0 !important; }
      #admin { display: none !important; }
      .print-hidden { display: none !important; }
      .cover {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .flow-step, .section-label, .step-num, .note {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .section { break-inside: avoid; }
      .step-box { break-inside: avoid; }
      .mockup-wrap { break-inside: avoid; }
      @page { size: A4; margin: 15mm 12mm; }
    }
  </style>
</head>
<body>

<!-- ===== 左サイドバー ===== -->
<nav class="sidebar">
  <div class="sidebar-logo">
    <div class="app-name">受注・出荷管理システム</div>
    <div class="sub">操作手順マニュアル</div>
  </div>

  <div class="nav-group-label">はじめに</div>
