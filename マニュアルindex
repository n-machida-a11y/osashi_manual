<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // スクロールに合わせてサイドバーのアクティブリンクを更新
  const sections = document.querySelectorAll('section[id], div.cover');
  const navLinks = document.querySelectorAll('.sidebar a');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(a => {
          a.classList.toggle('active', a.getAttribute('href') === '#' + entry.target.id);
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => observer.observe(s));

  // 画像設定
  const IMAGE_KEYS = ['img_import','img_dashboard','img_juchu','img_ordersheet','img_shipping','img_clerk','img_admin_db'];

  window.addEventListener('load', function() {
    if (typeof google !== 'undefined' && google.script) {
      loadImageSettings();
    }
  });

  function loadImageSettings() {
    google.script.run
      .withSuccessHandler(function(settings) {
        IMAGE_KEYS.forEach(function(key) {
          var input = document.getElementById(key);
          var status = document.getElementById('st_' + key);
          if (input) input.value = settings[key] || '';
          if (status) status.innerHTML = settings[key]
            ? '<span class="text-success fw-bold">✅ 設定済</span>'
            : '<span class="text-muted">未設定</span>';
        });
      })
      .getImageSettings();
  }

  function saveImageSettings() {
    var settings = {};
    IMAGE_KEYS.forEach(function(key) {
      var input = document.getElementById(key);
      if (input) settings[key] = input.value;
    });
    var msg = document.getElementById('save-msg');
    msg.textContent = '保存中...';
    msg.className = 'ms-3 fw-bold text-secondary';

    google.script.run
      .withSuccessHandler(function(result) {
        if (result.success) {
          msg.textContent = '✅ 保存しました。ページをリロードすると画像が反映されます。';
          msg.className = 'ms-3 fw-bold text-success';
          loadImageSettings();
        } else {
          msg.textContent = '❌ エラー: ' + result.error;
          msg.className = 'ms-3 fw-bold text-danger';
        }
      })
      .withFailureHandler(function(err) {
        msg.textContent = '❌ エラー: ' + err.message;
        msg.className = 'ms-3 fw-bold text-danger';
      })
      .saveImageSettings(settings);
  }
</script>
</body>
</html>
