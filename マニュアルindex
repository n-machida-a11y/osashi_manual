              <label class="btn btn-sm btn-outline-primary mb-0 upload-label">📁 選択<input type="file" accept="image/*" onchange="uploadImage(event,'img_admin_db')"></label>
            </div>
          </td>
          <td id="st_img_admin_db" class="text-center">—</td>
        </tr>
      </tbody>
    </table>
    <button class="btn btn-primary" onclick="saveImageSettings()">💾 ファイルIDを保存する</button>
    <span id="save-msg" class="ms-3 fw-bold"></span>

    <h3>GAS WebアプリのURL再発行</h3>
    <div class="step-box" style="border-left-color:#6c757d;">
      <h5>コード変更後のデプロイ手順</h5>
      <ol style="font-size:0.93rem;color:#333;line-height:1.9;margin-bottom:0;">
        <li>スプレッドシートのメニューから「拡張機能」→「Apps Script」を開く</li>
        <li>右上の「デプロイ」→「新しいデプロイ」をクリック</li>
        <li>「実行するユーザー：自分」「アクセスできるユーザー：全員」に設定して「デプロイ」</li>
        <li>発行されたURLを利用者へ共有する</li>
      </ol>
    </div>
  </section>

  <footer class="footer">
    <p>受注・出荷管理システム 操作手順マニュアル &copy; 2026</p>
    <p style="margin-top:4px;">ご不明点は社内の管理者担当者にお問い合わせください。</p>
  </footer>

</div><!-- /main -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // スクロール連動でサイドバーのアクティブリンク更新
  const navLinks = document.querySelectorAll('.sidebar a');
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function(a) {
          a.classList.toggle('active', a.getAttribute('href') === '#' + entry.target.id);
        });
      }
    });
  }, { rootMargin: '-25% 0px -65% 0px' });
  document.querySelectorAll('[id]').forEach(function(el) { observer.observe(el); });

  // 管理者向け：ページ読み込み時に設定を反映
  var isAdmin = false;
  var IMG_KEYS = ['img_login','img_menu','img_jimu_menu','img_juchu_list','img_juchu_detail','img_shipping','img_ordersheet','img_admin_db'];

  // 画像を非同期で1枚ずつ読み込む
  if (typeof google !== 'undefined') {
    window.addEventListener('load', function() {
      IMG_KEYS.forEach(function(key) {
        var imgs = document.querySelectorAll('img[data-key="' + key + '"]');
        if (!imgs.length) return;
        google.script.run
          .withSuccessHandler(function(base64) {
            if (!base64) return;
            imgs.forEach(function(img) {
              img.setAttribute('src', base64);
            });
          })
          .loadImageBase64(key);
      });
    });
  }

  window.addEventListener('load', loadImageSettings);

  function loadImageSettings() {
    google.script.run
      .withSuccessHandler(function(settings) {
        IMG_KEYS.forEach(function(key) {
          var input  = document.getElementById(key);
          var status = document.getElementById('st_' + key);
          if (input)  input.value = settings[key] || '';
          if (status) status.innerHTML = settings[key]
            ? '<span class="text-success fw-bold">✅ 設定済</span>'
            : '<span class="text-muted">未設定</span>';
        });
      })
      .getImageSettings();
  }

  // ファイルIDを直接入力して保存
  function saveImageSettings() {
    var settings = {};
    IMG_KEYS.forEach(function(key) {
      var input = document.getElementById(key);
      if (input) settings[key] = input.value;
    });
    var msg = document.getElementById('save-msg');
    msg.textContent = '保存中...';
    msg.className = 'ms-3 fw-bold text-secondary';
    google.script.run
      .withSuccessHandler(function(result) {
        if (result.success) {
          msg.textContent = '✅ 保存しました。リロードすると画像が反映されます。';
          msg.className = 'ms-3 fw-bold text-success';
          loadImageSettings();
        } else {
          msg.textContent = '❌ ' + result.error;
          msg.className = 'ms-3 fw-bold text-danger';
        }
      })
      .saveImageSettings(settings);
  }

  // 画像ファイルをアップロード → Driveに保存
  function uploadImage(event, imgKey) {
    var file = event.target.files[0];
    if (!file) return;
    var statusEl = document.getElementById('st_' + imgKey);
    if (statusEl) statusEl.innerHTML = '<span class="text-secondary">⏳ アップロード中...</span>';
    var reader = new FileReader();
    reader.onload = function(e) {
      var dataUrl  = e.target.result;
      var base64   = dataUrl.split(',')[1];
      google.script.run
        .withSuccessHandler(function(result) {
          if (result.success) {
            var input = document.getElementById(imgKey);
            if (input) input.value = result.fileId;
            if (statusEl) statusEl.innerHTML = '<span class="text-success fw-bold">✅ アップロード済</span>';
          } else {
            if (statusEl) statusEl.innerHTML = '<span class="text-danger">❌ ' + result.error + '</span>';
          }
        })
        .withFailureHandler(function(err) {
          if (statusEl) statusEl.innerHTML = '<span class="text-danger">❌ ' + err.message + '</span>';
        })
        .uploadImageToFolder(base64, file.type, file.name, imgKey);
    };
    reader.readAsDataURL(file);
  }
</script>
</body>
</html>
