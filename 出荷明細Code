function doGet(e) {
  try { DriveApp.getFiles(); } catch (e) {} 
  
  const juchuNo = e && e.parameter && e.parameter.juchuNo ? e.parameter.juchuNo : '';
  const slipId = e && e.parameter && e.parameter.slipId ? e.parameter.slipId : '';
  const tab = e && e.parameter && e.parameter.tab ? e.parameter.tab : '';

  if (!juchuNo && !slipId) {
    return HtmlService.createHtmlOutput('エラー：受注No または 伝票ID が指定されていません。AppSheetから開き直してください。');
  }

  const htmlTemplate = HtmlService.createTemplateFromFile('shukka');
  htmlTemplate.juchuNo = juchuNo;
  htmlTemplate.initialSlipId = slipId; 
  htmlTemplate.initialTab = tab;       
  
  return htmlTemplate.evaluate()
    .setTitle('出荷処理Webアプリ')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

function getJuchuNoBySlipId(slipId) {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID_DATA);
    const hSheet = ss.getSheetByName(SHEET_SHUKKA_HISTORY);
    const data = hSheet.getDataRange().getDisplayValues();
    const header = data[0];
    const idxSlip = header.indexOf('伝票ID');
    const idxJuchu = header.indexOf('受注No');
    
    const targetId = String(slipId).trim();

    for (let i = 1; i < data.length; i++) {
      if (String(data[i][idxSlip]).trim() === targetId) {
        return data[i][idxJuchu];
      }
    }
    return null;
  } catch(e) { return null; }
}

function getSalesOrderData(juchuNo, slipId = null) {
  try {
    if (!juchuNo && slipId) {
      juchuNo = getJuchuNoBySlipId(slipId);
      if (!juchuNo) throw new Error('指定された伝票IDが見つかりません');
    }

    const ss = SpreadsheetApp.openById(SPREADSHEET_ID_DATA);
    
    // ■ 作成者・確認者リストの取得（出荷明細担当者の列の値を直接使用）
    const tSheet = ss.getSheetByName(SHEET_TANTOSHA_MASTER);
    const tHeader = tSheet.getRange(1, 1, 1, tSheet.getLastColumn()).getValues()[0];
    const flagIdx = tHeader.indexOf('出荷明細担当者');
    const creatorList = [];
    if (flagIdx > -1) {
      const tData = tSheet.getDataRange().getValues();
      for (let i = 1; i < tData.length; i++) {
        const val = String(tData[i][flagIdx]).trim();
        // 空白やFALSEでなければ、入力された氏名としてリストに追加
        if (val !== '' && val.toUpperCase() !== 'FALSE') {
          creatorList.push(val);
        }
      }
    }

    // ■ 受注データの取得
    const jSheet = ss.getSheetByName(SHEET_JUCHU_DATA);
    const jHeader = jSheet.getRange(1, 1, 1, jSheet.getLastColumn()).getValues()[0];
    const jData = jSheet.getDataRange().getValues();
    const getIdx = (name) => jHeader.indexOf(name);
    
    let jRow = null;
    for (let i = 1; i < jData.length; i++) {
      if (String(jData[i][getIdx('受注No')]) === String(juchuNo)) {
        jRow = jData[i];
        break;
      }
    }
    if (!jRow) throw new Error(`受注No: ${juchuNo} が見つかりません`);

    // ■ JSONデータの取得
    const json1Idx = getIdx('出荷配送詳細(JSON)');
    const json2Idx = getIdx('出荷配送詳細(JSON2)');
    let deliveryList = [];
    if (json2Idx > -1 && jRow[json2Idx]) {
      try { deliveryList = JSON.parse(jRow[json2Idx]); } catch(e) {}
    } else if (json1Idx > -1 && jRow[json1Idx]) {
      try { deliveryList = JSON.parse(jRow[json1Idx]); } catch(e) {}
    }

    // ■ 担当者名の取得
    const tCode = jRow[getIdx('担当者コード')];
    let tName = '（担当者不明）';
    const tData2 = tSheet.getDataRange().getValues();
    for (let i = 1; i < tData2.length; i++) {
      if (String(tData2[i][0]) === String(tCode)) { tName = tData2[i][1]; break; }
    }

    // ■ 明細データの取得
    const mSheet = ss.getSheetByName(SHEET_JUCHU_MEISAI);
    const mHeader = mSheet.getRange(1, 1, 1, mSheet.getLastColumn()).getValues()[0];
    const mData = mSheet.getDataRange().getValues();
    const getMIdx = (name) => mHeader.indexOf(name);

    const meisaiList = [];
    for (let i = 1; i < mData.length; i++) {
      const row = mData[i];
      if (String(row[getMIdx('受注No')]) === String(juchuNo)) {
        const juchuSuryo = Number(row[getMIdx('数量')] || 0);
        const shukkaZumi = Number(row[getMIdx('出荷済数')] || 0);
        const kanoSuryo = juchuSuryo - shukkaZumi;
        
        if (juchuSuryo > 0) {
          meisaiList.push({
            meisaiNo: String(row[getMIdx('受注明細No')]),
            shohinCode: row[getMIdx('商品コード')],
            shohinName: row[getMIdx('商品名')],
            juchuSuryo: juchuSuryo,
            shukkaZumiSuryo: shukkaZumi,
            shukkaKanoSuryo: kanoSuryo,
            rowNum: i + 1
          });
        }
      }
    }

    const chokusosakiNameFromMeisai = jRow[getIdx('直送先名称_出荷明細')];

    return {
      status: 'success',
      juchuNo: juchuNo,
      targetSlipId: slipId,
      tokuisakiCode: jRow[getIdx('得意先コード')] || '',
      tokuisakiName: jRow[getIdx('得意先名')],
      tokuisakiName2: jRow[getIdx('得意先名２')] || '',
      chokusosakiName: chokusosakiNameFromMeisai || '',
      chokusosakiName2: jRow[getIdx('直送先名２')] || '',
      chokusosakiTantoshaName: jRow[getIdx('直送先担当者名')] || '',
      senpoTantoshaName: jRow[getIdx('先方担当者名')] || '',
      postalCode: jRow[getIdx('郵便番号')] || '',
      address1: jRow[getIdx('住所１')] || '',
      address2: jRow[getIdx('住所２')] || '',
      fmInfoNo: jRow[getIdx('FM情報No')] || '',
      fmShukkaNo: jRow[getIdx('FM出荷No')] || '',
      kaishaTel: jRow[getIdx('会社TEL')] || '',
      meisaiList: meisaiList,
      creatorList: creatorList, 
      deliveryList: deliveryList, 
      tantoshaName: tName
    };

  } catch (e) {
    return { status: 'error', message: e.message };
  }
}

