    return { status: 'success', historyList: historyList };
  } catch (e) {
    return { status: 'error', message: e.message };
  }
}

function getHistoryDetails(slipId) {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID_DATA);
    const lSheet = ss.getSheetByName(SHEET_SHUKKA_LOG);
    if (!lSheet) return { status: 'success', details: {} };

    const data = lSheet.getDataRange().getValues();
    const header = data[0];
    const slipIdIdx = header.indexOf('伝票ID');
    const itemIdx = header.indexOf('受注明細No');
    let qtyIdx = header.indexOf('出荷数量');
    if (qtyIdx === -1) qtyIdx = header.indexOf('出荷済数');
    
    if (slipIdIdx === -1 || qtyIdx === -1) return { status: 'success', details: {} };

    const details = {}; 
    const targetId = String(slipId).trim(); 

    for (let i = 1; i < data.length; i++) {
      if (String(data[i][slipIdIdx]).trim() === targetId) {
        const key = String(data[i][itemIdx]);
        const val = Number(data[i][qtyIdx]);
        details[key] = val;
      }
    }
    return { status: 'success', details: details };
  } catch (e) {
    return { status: 'error', message: e.message };
  }
}

// JSONの並び順を固定するヘルパー関数
function formatDeliveryList(list) {
  const keys = ["shipDate", "deliveryDate", "deliveryTime", "informationNo", "shippingNo", "deliveryMethod", "confirmName", "confirmDate"];
  return list.map(obj => {
    const newObj = {};
    keys.forEach(k => { newObj[k] = obj.hasOwnProperty(k) ? obj[k] : ""; });
    Object.keys(obj).forEach(k => { if(!newObj.hasOwnProperty(k)) newObj[k] = obj[k]; });
    return newObj;
  });
}

function processReturn(returnData) {
  try {
    const ssData = SpreadsheetApp.openById(SPREADSHEET_ID_DATA);
    const meisaiSheet = ssData.getSheetByName(SHEET_JUCHU_MEISAI);
    const colIdxShukkaZumi = meisaiSheet.getRange(1, 1, 1, meisaiSheet.getLastColumn()).getValues()[0].indexOf('出荷済数') + 1;
    
    let returnSheet = ssData.getSheetByName(SHEET_RETURN_HISTORY);
    if (!returnSheet) {
      returnSheet = ssData.insertSheet(SHEET_RETURN_HISTORY);
      returnSheet.appendRow([
        '処理日時', '返品日', '完了日', '返品依頼No', '送料負担', '送料金額',
        '受注No', '伝票ID', '受注明細No', '商品コード', '商品名', '返品数量', 'シリアルナンバー', '担当者名'
      ]);
    }

    const timestampStr = Utilities.formatDate(new Date(), 'JST', 'yyyy/MM/dd HH:mm:ss');

    returnData.items.forEach(item => {
      const returnQty = Number(item.returnQty);
      if (returnQty > 0 && item.rowNum) {
        const targetCell = meisaiSheet.getRange(item.rowNum, colIdxShukkaZumi);
        const currentZumi = Number(targetCell.getValue() || 0);
        targetCell.setValue(currentZumi - returnQty);

        const lastRow = returnSheet.getLastRow() + 1;
        const rowData = [
          timestampStr, returnData.returnDate, returnData.completeDate, returnData.returnReqNo,
          returnData.shippingCostType, returnData.shippingCost, returnData.juchuNo, returnData.slipId,
          String(item.meisaiNo), item.shohinCode, item.shohinName, returnQty, item.serialNo, ''
        ];
        returnSheet.appendRow(rowData);
        returnSheet.getRange(lastRow, 13).setNumberFormat('@');
        returnSheet.getRange(lastRow, 13).setValue(item.serialNo);
      }
    });
    return { status: 'success' };
  } catch (e) { return { status: 'error', message: e.message }; }
}

function processShipment(shipmentData) {
  return saveOrUpdateShipment(shipmentData, false);
}

function updateShipment(shipmentData) {
  return saveOrUpdateShipment(shipmentData, true);
}

function saveOrUpdateShipment(data, isUpdate) {
  try {
    const ssData = SpreadsheetApp.openById(SPREADSHEET_ID_DATA);
    const meisaiSheet = ssData.getSheetByName(SHEET_JUCHU_MEISAI);
    const colIdxShukkaZumi = meisaiSheet.getRange(1, 1, 1, meisaiSheet.getLastColumn()).getValues()[0].indexOf('出荷済数') + 1;
    const historySheet = ssData.getSheetByName(SHEET_SHUKKA_HISTORY);
    const logSheet = ssData.getSheetByName(SHEET_SHUKKA_LOG); 

    const now = new Date();
    const timestampStr = Utilities.formatDate(now, 'JST', 'yyyy/MM/dd HH:mm:ss');
    const currentJuchuNo = data.isIrregular ? data.newJuchuNo : data.juchuNo;

    const newSlipId = 'SH_' + Utilities.formatDate(now, 'JST', 'yyyyMMddHHmmss');
    const targetOldSlipId = isUpdate ? String(data.originalSlipId).trim() : '';

    // 1. 旧データの完全削除 と 在庫の復元
    const prevQuantities = {};
    if (isUpdate && !data.isIrregular) {
      const logData = logSheet.getDataRange().getValues();
      const lHeader = logData[0];
      const lSlipIdx = lHeader.indexOf('伝票ID');
      const lItemIdx = lHeader.indexOf('受注明細No');
      let lQtyIdx = lHeader.indexOf('出荷数量');
      if (lQtyIdx === -1) lQtyIdx = lHeader.indexOf('出荷済数');

      for (let i = logData.length - 1; i >= 1; i--) { 
        if (String(logData[i][lSlipIdx]).trim() === targetOldSlipId) {
          const mNo = String(logData[i][lItemIdx]);
          prevQuantities[mNo] = (prevQuantities[mNo] || 0) + Number(logData[i][lQtyIdx]);
          logSheet.deleteRow(i + 1); 
        }
      }

      const hData = historySheet.getDataRange().getValues();
      const hHeader = hData[0];
      const hSlipIdx = hHeader.indexOf('伝票ID');
      const hUrlIdx = hHeader.indexOf('ファイルURL');
      
      for (let i = hData.length - 1; i >= 1; i--) {
        if (String(hData[i][hSlipIdx]).trim() === targetOldSlipId) {
          const url = hData[i][hUrlIdx];
          const match = url ? url.match(/[-\w]{25,}/) : null;
          if (match) {
            try { DriveApp.getFileById(match[0]).setTrashed(true); } catch(e) { Logger.log("File Trash Error"); }
          }
          historySheet.deleteRow(i + 1);
          break;
        }
      }
    }

    // 2. 在庫の計算と更新
    if (!data.isIrregular) {
      data.items.forEach(item => {
        if (!item.isFreeInput) {
          const mNo = String(item.meisaiNo);
          const newQty = Number(item.shukkaSu); 
          const oldQty = (isUpdate) ? (prevQuantities[mNo] || 0) : 0;
          const diffQty = newQty - oldQty; 

          if (diffQty !== 0) {
            const targetCell = meisaiSheet.getRange(item.rowNum, colIdxShukkaZumi);
            const currentZumi = Number(targetCell.getValue() || 0);
            targetCell.setValue(currentZumi + diffQty);
          }
        }
      });
    }

    // 3. 新しいログデータの追加
    data.items.forEach((item, idx) => {
      const mNo = item.isFreeInput ? ('FREE_' + idx + '_' + timestampStr) : String(item.meisaiNo);
      if (item.shukkaSu > 0) {
        logSheet.appendRow([
          timestampStr, mNo, currentJuchuNo, item.shohinCode || '',
          item.shohinName, item.shukkaSu, data.shippingDate,
          data.arrivalDate, data.arrivalTime, newSlipId
        ]);
      }
    });

    // 4. 新しいファイル作成と動的フォルダへの保存
    const templateSS = SpreadsheetApp.openById(TEMPLATE_SPREADSHEET_ID);
    const shipDateForFile = data.shippingDate.replace(/-/g, '');
    const newFileName = `${currentJuchuNo}_${data.tokuisakiName}_${data.tokuisakiName2}_${shipDateForFile}_出荷明細`;
    const newSS = templateSS.copy(newFileName);
    const targetFileId = newSS.getId();
    const fileUrl = newSS.getUrl();
    
    // 出荷日のフォルダを作成/取得して格納
    try {
      const file = DriveApp.getFileById(targetFileId);
      const parentFolder = DriveApp.getFolderById(DESTINATION_FOLDER_ID);
      const folderName = shipDateForFile; // "20260220"
      const folders = parentFolder.getFoldersByName(folderName);
      let targetFolder;
      if (folders.hasNext()) {
        targetFolder = folders.next();
      } else {
        targetFolder = parentFolder.createFolder(folderName);
      }
      file.moveTo(targetFolder);
    } catch (e) {
      Logger.log("Folder Move Error: " + e.message);
    }

    const targetSS = SpreadsheetApp.openById(targetFileId);
    const targetSheet = targetSS.getSheetByName(TEMPLATE_SHEET_NAME);
    
    // ★修正時でも確認欄は常に「空欄」にする
    const replaceMap = {
      '％作成者％': data.creatorName || '',
      '%作成者%': data.creatorName || '',
      '％確認者％': '', 
      '%確認者%': '',
      '％担当者名％': data.tantoshaName || '',
      '%担当者名%': data.tantoshaName || '',
      '％受注番号％': currentJuchuNo,
      '%受注番号%': currentJuchuNo,
      '％得意先コード％': data.tokuisakiCode,
      '％得意先名％': data.tokuisakiName,
      '％得意先名２％': data.tokuisakiName2, 
      '％先方担当者％': data.senpoTantoshaName,
      '％直送先名１％': data.chokusosakiName,
      '％直送先名２％': data.chokusosakiName2,
      '％直送先担当者名％': data.chokusosakiTantoshaName,
      '％直送先郵便番号％': data.postalCode,
      '％直送先住所１％': data.address1,
      '％直送先住所２％': data.address2,
      '％FM情報No％': data.fmInfoNo,
      '％FM出荷No％': data.fmShukkaNo,
      '％会社TEL％': data.kaishaTel,
      '％出荷日％': data.shippingDate.replace(/-/g, '/'),
      '％到着日％': data.arrivalDate.replace(/-/g, '/'),
      '％到着時刻％': data.arrivalTime
    };

    // ★0落ちを防ぐために強制的にテキスト形式にする項目のキー
    const keysToTextFormat = [
      '％得意先コード％', '%得意先コード%', 
      '％FM情報No％', '%FM情報No%', 
      '％FM出荷No％', '%FM出荷No%',
      '％直送先郵便番号％', '%直送先郵便番号%'
    ];

    for (const [key, value] of Object.entries(replaceMap)) {
      const finder = targetSheet.createTextFinder(key);
      
      // 置換対象のセルを「テキスト形式」に設定して0落ちを防ぐ
      if (keysToTextFormat.includes(key)) {
        finder.findAll().forEach(r => r.setNumberFormat('@'));
      }
      
      finder.replaceAllWith(value);
    }
    
    const itemsToPrint = data.items.filter(item => !item.excludeFromSlip);
    const START_ROW = 14; 
    const TEMPLATE_ROWS = 20; 
    targetSheet.getRange(START_ROW, 1, TEMPLATE_ROWS, 1).clearContent();
    targetSheet.getRange(START_ROW, 16, TEMPLATE_ROWS, 1).clearContent();
    targetSheet.getRange(START_ROW, 18, TEMPLATE_ROWS, 1).clearContent();

    itemsToPrint.forEach((item, index) => {
      if (index < TEMPLATE_ROWS) { 
        const currentRow = START_ROW + index;
        targetSheet.getRange(currentRow, 1).setValue(item.shohinName); 
        targetSheet.getRange(currentRow, 16).setValue(item.shukkaSu); 
        // シリアルNoも先頭の0が消えないようにテキスト形式(@)に設定してから書き込む
        targetSheet.getRange(currentRow, 18).setNumberFormat('@').setValue(item.serialNo || '');
      }
    });

    const yamatoSheet = targetSS.getSheetByName(YAMATO_SHEET_NAME);
    if (yamatoSheet) {
      for (const [key, value] of Object.entries(replaceMap)) {
        const finder = yamatoSheet.createTextFinder(key);
        // ヤマト伝票シート側でも同様に0落ちを防ぐ
        if (keysToTextFormat.includes(key)) {
          finder.findAll().forEach(r => r.setNumberFormat('@'));
        }
        finder.replaceAllWith(value);
      }
    }
    const allSheets = targetSS.getSheets();
    if (allSheets.length > 2) {
      allSheets.forEach(sheet => {
        if (sheet.getName() !== TEMPLATE_SHEET_NAME && sheet.getName() !== YAMATO_SHEET_NAME) targetSS.deleteSheet(sheet);
      });
    }

    // 5. 新しい履歴シートの追加
    let hHeader = historySheet.getRange(1, 1, 1, historySheet.getLastColumn()).getValues()[0];
    if (hHeader.indexOf('作成者') === -1) { historySheet.getRange(1, hHeader.length + 1).setValue('作成者'); hHeader.push('作成者'); }
    if (hHeader.indexOf('対象タブ') === -1) { historySheet.getRange(1, hHeader.length + 1).setValue('対象タブ'); hHeader.push('対象タブ'); }

    const rowData = new Array(hHeader.length).fill('');
    const fillCol = (name, val) => { const idx = hHeader.indexOf(name); if(idx !== -1) rowData[idx] = val; };
    
    fillCol('伝票ID', newSlipId);
    fillCol('作成日時', timestampStr);
    fillCol('ファイルURL', fileUrl);
    fillCol('受注No', currentJuchuNo); 
    fillCol('出荷日', data.shippingDate);
    fillCol('到着日', data.arrivalDate);
    fillCol('到着時刻', data.arrivalTime);
    fillCol('得意先コード', data.tokuisakiCode);
    fillCol('得意先名', data.tokuisakiName);
    fillCol('先方担当者名', data.senpoTantoshaName);
    fillCol('直送先名', data.chokusosakiName);
    fillCol('直送先名２', data.chokusosakiName2);
    fillCol('直送先担当者名', data.chokusosakiTantoshaName);
    fillCol('郵便番号', data.postalCode);
    fillCol('住所１', data.address1);
    fillCol('住所２', data.address2);
    fillCol('会社TEL', data.kaishaTel);
    fillCol('FM情報No', data.fmInfoNo);
    fillCol('FM出荷No', data.fmShukkaNo);
    fillCol('作成者', data.creatorName);
    fillCol('対象タブ', data.targetTabIndex !== null ? data.targetTabIndex : ''); 
    
    historySheet.appendRow(rowData);
    
    // 6. JSON2の更新 および 宛先情報の更新
    if (!data.isIrregular) {
      const jSheet = ssData.getSheetByName(SHEET_JUCHU_DATA);
      const jHeader = jSheet.getRange(1, 1, 1, jSheet.getLastColumn()).getValues()[0];
      
      let json2Idx = jHeader.indexOf('出荷配送詳細(JSON2)') + 1;
      if (json2Idx === 0) {
        json2Idx = jHeader.length + 1;
        jSheet.getRange(1, json2Idx).setValue('出荷配送詳細(JSON2)');
      }
      const colIdxJNo = jHeader.indexOf('受注No') + 1;
      
      if (colIdxJNo > 0) {
        const jData = jSheet.getDataRange().getValues();
        for (let i = 1; i < jData.length; i++) {
          if (String(jData[i][colIdxJNo - 1]) === String(data.juchuNo)) {
            const r = i + 1;
            const sv = (name, val) => { const ci = jHeader.indexOf(name) + 1; if (ci > 0) jSheet.getRange(r, ci).setValue(val); };
            
            sv('FM情報No', data.fmInfoNo);
            sv('FM出荷No', data.fmShukkaNo);
            sv('直送先名称_出荷明細', data.chokusosakiName);
            sv('直送先名２', data.chokusosakiName2);
            sv('直送先担当者名', data.chokusosakiTantoshaName);
            sv('郵便番号', data.postalCode);
            sv('住所１', data.address1);
            sv('住所２', data.address2);
            sv('会社TEL', data.kaishaTel);
            
            if (data.deliveryList && data.deliveryList.length > 0) {
               // ★追加: 修正時はJSONデータ内の確認者情報もリセット（空欄に）する
               if (isUpdate && data.targetTabIndex !== null && data.deliveryList[data.targetTabIndex]) {
                  data.deliveryList[data.targetTabIndex].confirmName = '';
                  data.deliveryList[data.targetTabIndex].confirmDate = '';
               }
               
               // JSONキーの並び順を固定化
               const formattedList = formatDeliveryList(data.deliveryList);
               jSheet.getRange(r, json2Idx).setValue(JSON.stringify(formattedList));
            }
            break;
          }
        }
      }
    }

    return {
      status: 'success',
      newSheetUrl: fileUrl,
      newSheetName: '出荷明細書' + (isUpdate ? '(修正完了)' : '')
    };

  } catch (e) {
    Logger.log(e);
    return { status: 'error', message: e.message };
  }
}

function addConfirmName(juchuNo, slipId, confirmName) {
  try {
    const ssData = SpreadsheetApp.openById(SPREADSHEET_ID_DATA);
    const historySheet = ssData.getSheetByName(SHEET_SHUKKA_HISTORY);
    const hData = historySheet.getDataRange().getDisplayValues();
    const hHeader = hData[0];
    const hSlipIdx = hHeader.indexOf('伝票ID');
    const hUrlIdx = hHeader.indexOf('ファイルURL');
    const hTabIdx = hHeader.indexOf('対象タブ');
    
    let fileId = null;
    let targetTabIndex = -1;
    
    for(let i=hData.length-1; i>=1; i--) {
      if (String(hData[i][hSlipIdx]).trim() === String(slipId).trim()) {
        const url = hData[i][hUrlIdx];
        const match = url.match(/[-\w]{25,}/);
        if (match) fileId = match[0];
        if (hTabIdx > -1 && hData[i][hTabIdx] !== '') {
          targetTabIndex = parseInt(hData[i][hTabIdx], 10);
        }
        break;
      }
    }
    if (!fileId) throw new Error('伝票ファイルが見つかりません');
    
    // スプレッドシートの X40 に書き込み
    const targetSS = SpreadsheetApp.openById(fileId);
    const targetSheet = targetSS.getSheetByName(TEMPLATE_SHEET_NAME);
    if (targetSheet) {
      targetSheet.getRange('X40').setValue(confirmName);
    }
    
    // JSON2の更新 (対象タブがある場合)
    if (targetTabIndex >= 0) {
      const jSheet = ssData.getSheetByName(SHEET_JUCHU_DATA);
      const jHeader = jSheet.getRange(1, 1, 1, jSheet.getLastColumn()).getValues()[0];
      const json2Idx = jHeader.indexOf('出荷配送詳細(JSON2)') + 1;
      const colIdxJNo = jHeader.indexOf('受注No') + 1;
      
      if (json2Idx > 0 && colIdxJNo > 0) {
         const jData = jSheet.getDataRange().getValues();
         for (let i = 1; i < jData.length; i++) {
           if (String(jData[i][colIdxJNo - 1]) === String(juchuNo)) {
             const jsonStr = jData[i][json2Idx - 1];
             if (jsonStr) {
                try {
                  const list = JSON.parse(jsonStr);
                  if (list[targetTabIndex]) {
                     list[targetTabIndex].confirmName = confirmName;
                     const now = new Date();
                     list[targetTabIndex].confirmDate = Utilities.formatDate(now, 'JST', 'yyyy/MM/dd');
                     // ★JSONキーの並び順を固定化
                     const formattedList = formatDeliveryList(list);
                     jSheet.getRange(i + 1, json2Idx).setValue(JSON.stringify(formattedList));
                  }
                } catch(e) {}
             }
             break;
           }
         }
      }
    }
    return { status: 'success' };
  } catch(e) {
    return { status: 'error', message: e.message };
  }
}
