var ADMIN_EMAIL  = 'n-machida@race-number.co.jp';
var IMG_FOLDER_ID = '1U1UfITfe9ggy9sbCRj0QGJFJiKz02idD';
var IMG_KEYS = [
  'img_login',        // ログイン画面
  'img_menu',         // AppSheet メニュー画面
  'img_juchu_list',   // 受注兼 リスト画面
  'img_juchu_detail', // 受注兼 詳細画面
  'img_shipping',     // 出荷明細アプリ
  'img_confirm',      // 確認・処理完了
  'img_ordersheet',   // 注文書プレビュー
  'img_admin_db'      // 管理用スプレッドシート
];

function doGet() {
  var tmpl  = HtmlService.createTemplateFromFile('マニュアルindex');
  var props = PropertiesService.getScriptProperties();

  IMG_KEYS.forEach(function(key) {
    var fileId = props.getProperty(key) || '';
    tmpl[key]  = fileId ? fileToBase64(fileId) : '';
  });

  tmpl.isAdmin = (Session.getActiveUser().getEmail() === ADMIN_EMAIL);

  return tmpl.evaluate()
    .setTitle('受注・出荷管理システム マニュアル')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

/* ---- 内部ユーティリティ ---- */
function fileToBase64(fileId) {
  try {
    var blob = DriveApp.getFileById(fileId).getBlob();
    return 'data:' + blob.getContentType() + ';base64,' + Utilities.base64Encode(blob.getBytes());
  } catch(e) {
    return '';
  }
}

function checkAdmin() {
  if (Session.getActiveUser().getEmail() !== ADMIN_EMAIL) {
    throw new Error('この操作は管理者のみ実行できます。');
  }
}

/* ---- 画像アップロード（指定フォルダへ保存） ---- */
function uploadImageToFolder(base64Data, mimeType, fileName, imgKey) {
  try {
    checkAdmin();
    var folder = DriveApp.getFolderById(IMG_FOLDER_ID);
    var bytes  = Utilities.base64Decode(base64Data);
    var blob   = Utilities.newBlob(bytes, mimeType, fileName);
    var file   = folder.createFile(blob);
    PropertiesService.getScriptProperties().setProperty(imgKey, file.getId());
    return { success: true, fileId: file.getId() };
  } catch(e) {
    return { success: false, error: e.message };
  }
}

/* ---- ファイルID直接入力で保存 ---- */
function saveImageSettings(settings) {
  try {
    checkAdmin();
    var props = PropertiesService.getScriptProperties();
    Object.keys(settings).forEach(function(key) {
      var val = settings[key];
      if (val && val.trim()) props.setProperty(key, val.trim());
      else props.deleteProperty(key);
    });
    return { success: true };
  } catch(e) {
    return { success: false, error: e.message };
  }
}

/* ---- 現在の設定を返す ---- */
function getImageSettings() {
  try {
    checkAdmin();
    var props  = PropertiesService.getScriptProperties();
    var result = {};
    IMG_KEYS.forEach(function(key) {
      result[key] = props.getProperty(key) || '';
    });
    return result;
  } catch(e) {
    return {};
  }
}
